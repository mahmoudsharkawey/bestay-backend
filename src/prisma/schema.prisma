generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum Role {
  USER
  LANDLORD
  ADMIN
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
  PENDING_REFUND
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum UnitType {
  ROOM
  APARTMENT
  STUDIO
}

enum RoomType {
  SINGLE
  DOUBLE
  SHARED
}

enum GenderPreference {
  MALE_ONLY
  FEMALE_ONLY
}

enum NotificationType {
  VISIT_REQUEST
  VISIT_APPROVED
  VISIT_RESCHEDULED
  VISIT_REJECTED
  VISIT_CANCELLED
  VISIT_CONFIRMED
  PAYMENT_CONFIRMED
  PAYMENT_REFUNDED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_RESCHEDULED
  BOOKING_REJECTED
}

enum UnitStatus {
  ACTIVE
  DELETED
}

enum VisitStatus {
  PENDING_OWNER
  APPROVED
  REJECTED_BY_OWNER
  RESCHEDULE_PROPOSED
  REJECTED_BY_USER
  CANCELLED_BY_USER
  CANCELLED_BY_OWNER
  REFUNDED
  CONFIRMED
}

enum BookingStatus {
  CONFIRMED
  BOOKED
  CANCELLED
}

//////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String?
  phone     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  provider   AuthProvider @default(LOCAL)
  providerId String?
  picture    String?

  passwordResetCode     String?
  passwordResetExpiry   DateTime?
  passwordResetVerified Boolean   @default(false)

  deletedAt   DateTime?
  deletedById String?

  visits        Visit[]
  units         Unit[]          @relation("OwnerUnits")
  bookings      Booking[]
  preferences   UserPreference?
  reviews       Review[]
  favorites     Favorite[]
  payments      Payment[]
  notifications Notification[]

  @@unique([provider, providerId])
  @@index([email])
  @@index([role])
}

//////////////////////////////////////////////////
// USER PREFERENCES (AI INPUT)
//////////////////////////////////////////////////

model UserPreference {
  id       String   @id @default(uuid())
  userId   String   @unique
  unitType UnitType

  minBudget   Float
  maxBudget   Float
  city        String
  university  String?
  maxDistance Float? // optional distance from university (km)

  rooms      Int
  furnished  Boolean
  genderType GenderPreference // e.g., MALE_ONLY, FEMALE_ONLY
  facilities String[] // e.g., ["wifi", "parking", "gym"]

  user User @relation(fields: [userId], references: [id])
}

//////////////////////////////////////////////////
// UNIT (PROPERTY LISTING)
//////////////////////////////////////////////////

model Unit {
  id          String  @id @default(uuid())
  title       String
  description String
  price       Float
  city        String
  address     String
  rooms       Int
  furnished   Boolean

  university String?
  distance   Float? // distance from university (km)

  status      UnitStatus @default(ACTIVE)
  deletedAt   DateTime?
  deletedById String?

  roomType   RoomType
  genderType GenderPreference

  facilities String[] // e.g., ["wifi", "parking", "gym"]
  images     String[] // URLs of unit images

  ownerId String
  owner   User   @relation("OwnerUnits", fields: [ownerId], references: [id])

  latitude  Float?
  longitude Float?

  bookings  Booking[]
  reviews   Review[]
  favorites Favorite[]

  createdAt DateTime @default(now())
  visits    Visit[]

  @@index([city])
  @@index([status])
  @@index([ownerId])
  @@index([price])
  @@index([roomType])
  @@index([deletedAt])
}

//////////////////////////////////////////////////
// BOOKING
//////////////////////////////////////////////////

model Booking {
  id      String        @id @default(uuid())
  userId  String
  unitId  String
  visitId String        @unique
  status  BookingStatus

  user  User  @relation(fields: [userId], references: [id])
  unit  Unit  @relation(fields: [unitId], references: [id])
  visit Visit @relation(fields: [visitId], references: [id])

  createdAt DateTime @default(now())
  payment   Payment? @relation(fields: [paymentId], references: [id])
  paymentId String?

  deletedAt   DateTime?
  deletedById String?
}

//////////////////////////////////////////////////
// VISIT
//////////////////////////////////////////////////

model Visit {
  id              String      @id @default(uuid())
  userId          String
  unitId          String
  proposedDate    DateTime
  pendingDate     DateTime? // Holds owner's reschedule proposal until user accepts
  status          VisitStatus
  rescheduleCount Int         @default(0)
  paymentPaid     Boolean     @default(false)

  user    User     @relation(fields: [userId], references: [id])
  unit    Unit     @relation(fields: [unitId], references: [id])
  payment Payment?
  booking Booking?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  paymentId String?

  deletedAt   DateTime?
  deletedById String?

  @@index([userId])
  @@index([unitId])
  @@index([status])
  @@index([proposedDate])
  @@index([userId, unitId, status])
}

//////////////////////////////////////////////////
// PAYMENT
//////////////////////////////////////////////////

model Payment {
  id             String        @id @default(uuid())
  userId         String
  visitId        String        @unique
  amount         Int // Stored in piastres/cents (smallest currency unit)
  status         PaymentStatus
  stripeIntentId String?
  refundedAt     DateTime?

  user  User  @relation(fields: [userId], references: [id])
  visit Visit @relation(fields: [visitId], references: [id])

  createdAt DateTime  @default(now())
  bookings  Booking[]
}

//////////////////////////////////////////////////
// REVIEW
//////////////////////////////////////////////////

model Review {
  id      String  @id @default(uuid())
  rating  Int // 1–5
  comment String?

  userId String
  unitId String

  user User @relation(fields: [userId], references: [id])
  unit Unit @relation(fields: [unitId], references: [id])

  createdAt DateTime @default(now())

  deletedAt   DateTime?
  deletedById String?

  @@unique([userId, unitId])
}

//////////////////////////////////////////////////
// FAVORITE
//////////////////////////////////////////////////

model Favorite {
  id     String @id @default(uuid())
  userId String
  unitId String

  user User @relation(fields: [userId], references: [id])
  unit Unit @relation(fields: [unitId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, unitId])
}

//////////////////////////////////////////////////
// NOTIFICATION
//////////////////////////////////////////////////

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
}
